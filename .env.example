# Copy this to .env and fill in your values

# Your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Flask secret key (generate with: python3 -c "import secrets; print(secrets.token_hex(16))")
SECRET_KEY=change-me-to-something-random

# User accounts (format: USER_<NAME>_PASSWORD=<password>)
USER_YOURNAME_PASSWORD=your-password-here
USER_PARTNER_PASSWORD=partner-password-here
